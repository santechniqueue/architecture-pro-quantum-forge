# Пример файла .env для Task04 (RAG-бот)

# OpenAI-compatible эндпоинт (OpenAI / прокси / совместимые шлюзы)
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=qwen2.5:7b-instruct

# Где лежит собранный индекс из Task03
INDEX_DIR=Task03/index

# Параметры ретривера
RAG_TOP_K=5
RAG_MIN_SCORE=0.78

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=0.9
OPENAI_MAX_TOKENS=600